{
  "name": "dryft-mobile",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "generate-assets": "node scripts/generate-assets.js",
    "prebuild": "expo prebuild",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "11.1.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@sentry/react-native": "~5.19.0",
    "@stripe/stripe-react-native": "^0.35.0",
    "@types/uuid": "^10.0.0",
    "expo": "~50.0.0",
    "expo-application": "~5.8.0",
    "expo-av": "~13.10.0",
    "expo-background-fetch": "^14.0.9",
    "expo-blur": "~12.9.2",
    "expo-camera": "~14.0.0",
    "expo-clipboard": "~5.0.0",
    "expo-constants": "~15.4.0",
    "expo-device": "~5.9.0",
    "expo-face-detector": "~12.6.0",
    "expo-file-system": "~16.0.0",
    "expo-haptics": "~12.8.0",
    "expo-image": "~1.10.0",
    "expo-image-manipulator": "~11.8.0",
    "expo-image-picker": "~14.7.0",
    "expo-linear-gradient": "~12.7.2",
    "expo-linking": "~6.2.0",
    "expo-local-authentication": "~13.8.0",
    "expo-localization": "~14.8.0",
    "expo-location": "~16.5.0",
    "expo-mail-composer": "^15.0.8",
    "expo-notifications": "~0.27.0",
    "expo-quick-actions": "^6.0.1",
    "expo-secure-store": "~12.8.0",
    "expo-sharing": "~11.10.0",
    "expo-sms": "^14.0.8",
    "expo-splash-screen": "~0.26.0",
    "expo-status-bar": "~1.11.0",
    "expo-store-review": "~6.8.0",
    "expo-task-manager": "^14.0.9",
    "expo-updates": "~0.24.0",
    "expo-web-browser": "~12.8.0",
    "i18next": "^23.7.0",
    "react": "18.2.0",
    "react-i18next": "^14.0.0",
    "react-native": "0.73.0",
    "react-native-callkeep": "^4.3.16",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-maps": "1.10.0",
    "react-native-purchases": "^9.9.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-voip-push-notification": "^3.3.3",
    "react-native-webrtc": "^118.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "~18.2.45",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.0",
    "prettier": "^3.2.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.1.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/src/__tests__/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@screens/(.*)$": "<rootDir>/src/screens/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@api/(.*)$": "<rootDir>/src/api/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@navigation/(.*)$": "<rootDir>/src/navigation/$1",
      "^@i18n/(.*)$": "<rootDir>/src/i18n/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/__tests__/**",
      "!src/types/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 40,
        "branches": 40,
        "functions": 40,
        "lines": 40
      }
    }
  },
  "private": true
}
