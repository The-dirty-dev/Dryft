{
  "expo": {
    "name": "Dryft",
    "slug": "dryft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "dryft",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dryft.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Dryft needs camera access for profile photos, video calls, and verification.",
        "NSMicrophoneUsageDescription": "Dryft needs microphone access for voice messages and video calls.",
        "NSPhotoLibraryUsageDescription": "Dryft needs photo library access to share photos in chat and update your profile.",
        "NSLocationWhenInUseUsageDescription": "Dryft uses your location to show nearby matches and suggest date spots.",
        "NSFaceIDUsageDescription": "Use Face ID to securely unlock your account.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_IOS_API_KEY"
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.dryft.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_ANDROID_API_KEY"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "dryft.site",
              "pathPrefix": "/"
            },
            {
              "scheme": "dryft"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dryft to access your camera for profile photos, video calls, and verification."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dryft to access your photos for sharing in chat and profile."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Dryft to use your location for finding nearby matches."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Dryft to use Face ID to secure your account."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6",
          "sounds": [
            "./assets/sounds/notification.wav",
            "./assets/sounds/match.wav"
          ]
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.dryft.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Dryft to access your microphone for voice messages and calls."
        }
      ],
      "expo-secure-store",
      "expo-localization",
      [
        "./plugins/withScreenSecurity",
        {
          "enableByDefault": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "owner": "dryft",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    }
  }
}
