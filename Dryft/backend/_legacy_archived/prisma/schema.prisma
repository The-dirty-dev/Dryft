// =============================================================================
// Admin & Moderation
// =============================================================================

model AdminAction {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  action      String   // BAN_USER, UNBAN_USER, WARN_USER, APPROVE_VERIFICATION, etc.
  targetType  String   @map("target_type") // USER, REPORT, STORY, etc.
  targetId    String   @map("target_id")
  reason      String?
  metadata    Json?

  createdAt   DateTime @default(now()) @map("created_at")

  @@map("admin_actions")
}

model UserPhoto {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  photoUrl    String   @map("photo_url")
  orderIndex  Int      @default(0) @map("order_index")
  isVerification Boolean @default(false) @map("is_verification")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_photos")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  stripePaymentId String?  @map("stripe_payment_id")

  amount          Int      // In cents
  currency        String   @default("usd")
  type            PaymentType
  status          PaymentStatus @default(PENDING)

  description     String?
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([stripePaymentId])
  @@index([status, createdAt])
  @@map("payments")
}

enum PaymentType {
  SUBSCRIPTION
  GIFT
  MARKETPLACE
  BOOST
  SUPER_LIKE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// =============================================================================
// Daily Rewards
// =============================================================================

model DailyReward {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")

  streakDay       Int      @map("streak_day")
  xpEarned        Int      @map("xp_earned")
  coinsEarned     Int      @default(0) @map("coins_earned")
  milestoneReached String? @map("milestone_reached")

  claimedAt       DateTime @default(now()) @map("claimed_at")

  @@index([userId, claimedAt])
  @@map("daily_rewards")
}

// =============================================================================
// Tips
// =============================================================================

model Tip {
  id              String     @id @default(uuid())
  senderId        String     @map("sender_id")
  recipientId     String     @map("recipient_id")

  amount          Int        // In cents
  currency        String     @default("usd")
  message         String?
  isAnonymous     Boolean    @default(false) @map("is_anonymous")

  stripePaymentId String?    @map("stripe_payment_id")
  status          TipStatus  @default(PENDING)

  createdAt       DateTime   @default(now()) @map("created_at")
  completedAt     DateTime?  @map("completed_at")

  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@map("tips")
}

enum TipStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// =============================================================================
// Shared Subscriptions
// =============================================================================

model SharedSubscription {
  id              String                   @id @default(uuid())
  ownerId         String                   @map("owner_id")

  // The tier being shared (PREMIUM = 1 slot, VIP = 2 slots)
  sharedTier      SubscriptionTier         @map("shared_tier")

  // Status
  status          SharedSubscriptionStatus @default(ACTIVE)

  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  // Relations
  members         SharedSubscriptionMember[]

  @@unique([ownerId])
  @@index([status])
  @@map("shared_subscriptions")
}

model SharedSubscriptionMember {
  id                    String                     @id @default(uuid())
  sharedSubscriptionId  String                     @map("shared_subscription_id")
  sharedSubscription    SharedSubscription         @relation(fields: [sharedSubscriptionId], references: [id], onDelete: Cascade)

  // Invited user (null until accepted)
  userId                String?                    @map("user_id")

  // Invitation details
  inviteEmail           String?                    @map("invite_email")
  inviteCode            String?                    @unique @map("invite_code")
  invitedAt             DateTime                   @default(now()) @map("invited_at")

  // Acceptance
  status                SharedMemberStatus         @default(PENDING)
  acceptedAt            DateTime?                  @map("accepted_at")
  revokedAt             DateTime?                  @map("revoked_at")

  @@unique([sharedSubscriptionId, userId])
  @@unique([sharedSubscriptionId, inviteEmail])
  @@index([userId])
  @@index([inviteCode])
  @@index([inviteEmail])
  @@map("shared_subscription_members")
}

enum SharedSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SharedMemberStatus {
  PENDING    // Invitation sent
  ACCEPTED   // User accepted
  REVOKED    // Owner revoked access
  LEFT       // User left voluntarily
  EXPIRED    // Subscription expired
}

// =============================================================================
// Seasonal Pass
// =============================================================================

model Season {
  id              String       @id @default(uuid())
  name            String
  description     String?
  theme           String?      // e.g., "Summer Love", "Valentine's"

  startsAt        DateTime     @map("starts_at")
  endsAt          DateTime     @map("ends_at")

  // Pass pricing
  passPrice       Int          @default(999) @map("pass_price") // $9.99
  premiumPassPrice Int         @default(1999) @map("premium_pass_price") // $19.99

  isActive        Boolean      @default(false) @map("is_active")

  createdAt       DateTime     @default(now()) @map("created_at")

  tiers           SeasonTier[]
  passes          SeasonPass[]

  @@map("seasons")
}

model SeasonTier {
  id              String       @id @default(uuid())
  seasonId        String       @map("season_id")
  season          Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  level           Int
  xpRequired      Int          @map("xp_required")

  // Free rewards
  freeRewardType  String?      @map("free_reward_type") // XP, COINS, BADGE, ITEM
  freeRewardValue String?      @map("free_reward_value")

  // Premium rewards
  premiumRewardType  String?   @map("premium_reward_type")
  premiumRewardValue String?   @map("premium_reward_value")

  @@unique([seasonId, level])
  @@map("season_tiers")
}

model SeasonPass {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  seasonId        String       @map("season_id")
  season          Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  passType        SeasonPassType @default(FREE) @map("pass_type")
  currentXp       Int          @default(0) @map("current_xp")
  currentLevel    Int          @default(1) @map("current_level")

  claimedTiers    Int[]        @map("claimed_tiers") // Array of claimed tier levels

  purchasedAt     DateTime?    @map("purchased_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@unique([userId, seasonId])
  @@map("season_passes")
}

enum SeasonPassType {
  FREE
  PREMIUM
}

// =============================================================================
// Content Moderation
// =============================================================================

model ContentFlag {
  id              String       @id @default(uuid())

  contentType     ContentType  @map("content_type")
  contentId       String       @map("content_id")
  userId          String?      @map("user_id") // Content owner

  // Detection info
  source          FlagSource
  confidence      Float?       // AI confidence score 0-1
  categories      String[]     // e.g., ["nudity", "violence"]
  details         Json?        // Raw AI response

  // Review
  status          FlagStatus   @default(PENDING)
  reviewedBy      String?      @map("reviewed_by")
  reviewedAt      DateTime?    @map("reviewed_at")
  resolution      String?      // APPROVED, REMOVED, WARNING
  notes           String?

  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([contentType, contentId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("content_flags")
}

enum ContentType {
  PROFILE_PHOTO
  STORY
  MESSAGE
  BIO
  PROMPT
}

enum FlagSource {
  AI_AUTO       // Automatic AI detection
  USER_REPORT   // User reported
  ADMIN_MANUAL  // Admin flagged
}

enum FlagStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

// =============================================================================
// Scam Detection
// =============================================================================

model ScamAlert {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")

  alertType       ScamAlertType @map("alert_type")
  severity        AlertSeverity
  confidence      Float        // 0-1 score

  // Detection details
  indicators      String[]     // What triggered the alert
  evidence        Json?        // Supporting data
  messageIds      String[]     @map("message_ids") // Related messages

  // Resolution
  status          AlertStatus  @default(ACTIVE)
  resolvedBy      String?      @map("resolved_by")
  resolvedAt      DateTime?    @map("resolved_at")
  resolution      String?      // FALSE_POSITIVE, CONFIRMED, WARNING_SENT, BANNED

  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([userId, status])
  @@index([alertType, status])
  @@map("scam_alerts")
}

enum ScamAlertType {
  ROMANCE_SCAM       // Classic romance scam patterns
  FINANCIAL_REQUEST  // Asking for money
  EXTERNAL_LINK      // Suspicious external links
  RAPID_ESCALATION   // Moving too fast (asking for personal info)
  BOT_BEHAVIOR       // Automated/scripted messages
  IMPERSONATION      // Fake profile indicators
  CRYPTO_SCAM        // Cryptocurrency investment scams
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  INVESTIGATING
  RESOLVED
  FALSE_POSITIVE
}

// =============================================================================
// Security Logging
// =============================================================================

model SecurityLog {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")

  eventType       SecurityEventType @map("event_type")
  metadata        Json?        // Event-specific data (session codes, etc.)
  ipAddress       String?      @map("ip_address")
  userAgent       String?      @map("user_agent")

  createdAt       DateTime     @default(now()) @map("created_at")

  user            User         @relation(fields: [userId], references: [id])

  @@index([userId, eventType])
  @@index([eventType, createdAt])
  @@map("security_logs")
}

enum SecurityEventType {
  VR_RECORDING_DETECTED       // VR headset recording detected
  MOBILE_CAPTURE_DETECTED     // Mobile screenshot/recording detected
  SCREEN_SECURITY_ENABLED     // User enabled screen security
  SCREEN_SECURITY_DISABLED    // User disabled screen security
  SUSPICIOUS_LOGIN            // Login from unusual location/device
  PASSWORD_RESET_REQUESTED    // Password reset initiated
  ACCOUNT_LOCKED              // Account temporarily locked
  FAILED_LOGIN_ATTEMPTS       // Multiple failed login attempts
}
